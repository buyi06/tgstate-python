# All settings are optional. You can configure everything through the web UI.
# Just run the app and visit http://127.0.0.1:8000 to get started.

# [Optional] Telegram Bot Token from @BotFather
# BOT_TOKEN=

# [Optional] File storage channel (@channel_name or -100xxxxxxxxxx)
# CHANNEL_NAME=

# [Optional] Web interface password
# PASS_WORD=

# [Optional] PicGo API upload key
# PICGO_API_KEY=

# [Optional] Public access URL for share links
# BASE_URL=http://127.0.0.1:8000

# [Optional] Log level (default: info)
# LOG_LEVEL=info

# [Optional] Data directory (default: app/data)
# DATA_DIR=app/data
